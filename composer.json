{
    "name": "claude/coverletter",
    "description": "AI-powered Cover Letter Generator",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "dompdf/dompdf": "^2.0",
        "smalot/pdfparser": "^2.0",
        "phpoffice/phpword": "^1.4",
        "stripe/stripe-php": "^19.4",
        "phpmailer/phpmailer": "^7.0",
        "ezyang/htmlpurifier": "^4.19"
    },
    "autoload": {
        "classmap": [
            "core/",
            "app/Controllers/",
            "app/Models/",
            "app/Services/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "php-webdriver/webdriver": "^1.16",
        "phpdocumentor/phpdocumentor": "^3.9"
    }
}
